// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  USER
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseImageSource {
  UPLOAD
  EXTERNAL_URL
}

enum CourseEventType {
  VIEW
  CLICK_EXTERNAL
}

enum EmailRecipientStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  SKIPPED
}

enum EmailBatchStatus {
  QUEUED
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  BLOCKED
}

enum NotificationType {
  COURSE_PUBLISHED
}

model User {
  id                 String                @id @default(cuid())
  name               String
  email              String                @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?
  role               UserRole              @default(USER)
  notificationOptIn  Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  accounts           Account[]
  sessions           Session[]
  authoredCourses    Course[]              @relation("CourseAuthor")
  courseEvents       CourseEvent[]
  likes              CourseLike[]
  reviews            CourseReview[]
  comments           CourseComment[]
  emailBatches       EmailBatch[]          @relation("EmailBatchCreatedBy")
  emailBatchReceipts EmailBatchRecipient[]
  notifications      UserNotification[]
  createdNotifications Notification[]      @relation("NotificationCreatedBy")
  passwordResetCodes PasswordResetCode[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetCode {
  id           String    @id @default(cuid())
  userId       String
  email        String
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt])
  @@index([userId, consumedAt, expiresAt])
}

model Course {
  id           String          @id @default(cuid())
  slug         String          @unique
  title        String
  summary      String
  description  String
  externalUrl  String
  status       CourseStatus    @default(DRAFT)
  isFeatured   Boolean         @default(false)
  authorId     String
  publishedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  author       User            @relation("CourseAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  images       CourseImage[]
  events       CourseEvent[]
  likes        CourseLike[]
  reviews      CourseReview[]
  comments     CourseComment[]
  emailBatches EmailBatch[]
  notifications Notification[]

  @@index([status, publishedAt])
  @@index([authorId])
}

model CourseImage {
  id        String            @id @default(cuid())
  courseId  String
  source    CourseImageSource
  url       String
  alt       String
  sortOrder Int               @default(0)
  createdAt DateTime          @default(now())
  course    Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, sortOrder])
}

model CourseEvent {
  id        String          @id @default(cuid())
  courseId  String
  userId    String?
  type      CourseEventType
  createdAt DateTime        @default(now())
  course    Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([courseId, type, createdAt])
  @@index([userId, createdAt])
}

model CourseLike {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId, createdAt])
}

model CourseReview {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  rating    Int
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId, rating])
}

model CourseComment {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([courseId, createdAt])
}

model EmailBatch {
  id                String                @id @default(cuid())
  courseId          String
  createdById       String
  status            EmailBatchStatus      @default(QUEUED)
  totalRecipients   Int                   @default(0)
  sentCount         Int                   @default(0)
  failedCount       Int                   @default(0)
  skippedCount      Int                   @default(0)
  lastError         String?
  processingStartedAt DateTime?
  completedAt       DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  course            Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy         User                  @relation("EmailBatchCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  recipients        EmailBatchRecipient[]

  @@index([courseId, createdAt])
  @@index([status, processingStartedAt])
}

model EmailBatchRecipient {
  id              String                @id @default(cuid())
  batchId      String
  userId       String?
  email        String
  status       EmailRecipientStatus @default(PENDING)
  attemptCount Int                  @default(0)
  lastAttemptAt DateTime?
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime             @default(now())
  batch        EmailBatch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user         User?                @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([batchId, status])
  @@index([batchId, attemptCount])
  @@index([email])
}

model Notification {
  id          String             @id @default(cuid())
  type        NotificationType
  title       String
  body        String
  href        String
  courseId    String?
  createdById String?
  createdAt   DateTime           @default(now())
  course      Course?            @relation(fields: [courseId], references: [id], onDelete: SetNull)
  createdBy   User?              @relation("NotificationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  recipients  UserNotification[]

  @@index([createdAt])
  @@index([courseId, createdAt])
}

model UserNotification {
  id             String        @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime?
  createdAt      DateTime      @default(now())
  notification   Notification  @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt, createdAt])
  @@index([notificationId, createdAt])
}
